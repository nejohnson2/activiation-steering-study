#!/bin/bash
#SBATCH --job-name=steer-gen
#SBATCH --partition=h200x4
#SBATCH --gres=gpu:1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=08:00:00
#SBATCH --output=/lustre/nvwulf/scratch/nijjohnson/logs/steering_%j.out
#SBATCH --error=/lustre/nvwulf/scratch/nijjohnson/logs/steering_%j.err

# --- Environment Setup ---
module load cuda12.8/toolkit/12.8.0
conda activate steering-study

export HF_HOME=/lustre/nvwulf/scratch/nijjohnson/hf_cache
export HF_TOKEN=$(cat ${HOME}/.cache/huggingface/token)

# --- Working Directory ---
cd /lustre/nvwulf/scratch/nijjohnson/activation-steering-study

# --- Run Steering ---
python scripts/run_steering.py \
    --config configs/default.yaml \
    ${MODEL:+--model $MODEL} \
    ${PERSONA:+--persona $PERSONA}

echo "Steering job $SLURM_JOB_ID completed at $(date)"
